{
  "title": "NCE Event Explorer",
  "max_depth": 4,
  "default_limit": 50,
  "panes": {
    "pane_1": {
      "label": "Events",
      "doctype": "Events",
      "columns": [
        { "fieldname": "first_session_date", "fieldtype": "Date", "label": "First Session" },
        { "fieldname": "event_name", "fieldtype": "Data", "label": "Event Name" },
        { "fieldname": "_player_count", "fieldtype": "Int", "label": "# Players", "computed": true, "source": "COUNT(Registrations WHERE product_id = event)" }
      ],
      "sort": "first_session_date ASC",
      "filters_baked_in": {
        "first_session_date": [">", "today - 30 days"],
        "product_type": ["in", ["Training", "Tryouts", "Camp"]]
      },
      "filters_user_editable": false,
      "link_to_parent": null
    },
    "pane_2": {
      "label": "Players",
      "doctype": "Family Members",
      "join": {
        "through": "Registrations",
        "parent_link": "Registrations.product_id → Events",
        "child_link": "Registrations.player_id → Family Members"
      },
      "columns": [
        {
          "fieldname": "_full_name",
          "fieldtype": "Data",
          "label": "Name",
          "computed": true,
          "source": "CONCAT(last_name, ', ', first_name)",
          "style": {
            "color_rule": {
              "field": "gender",
              "map": { "Male": "blue", "Female": "crimson" }
            }
          }
        },
        { "fieldname": "yob", "fieldtype": "Int", "label": "YOB" },
        { "fieldname": "rating", "fieldtype": "Int", "label": "Rating" },
        {
          "fieldname": "_family_email",
          "fieldtype": "Data",
          "label": "Email",
          "computed": true,
          "source": "Families.email via Family Members.wp_parent_user_id"
        }
      ],
      "sort": "gender ASC, last_name ASC",
      "sort_note": "Female before Male (F < M alphabetically)",
      "filters_baked_in": null,
      "filters_user_editable": false,
      "header_buttons": [
        { "label": "Send Email", "action": null, "note": "not wired up yet" },
        { "label": "Send SMS", "action": null, "note": "not wired up yet" }
      ]
    },
    "pane_3": null,
    "pane_4": null
  },
  "layout": {
    "style": "Chrome split-view",
    "container": {
      "display": "flex",
      "direction": "row",
      "height": "fills available page height (calc 100vh minus Frappe navbar/breadcrumb)",
      "overflow": "hidden"
    },
    "panes": {
      "max_count": 4,
      "default_width": "equal split of available space",
      "min_width_px": 200,
      "vertical_scroll": "each pane scrolls independently (overflow-y: auto)",
      "horizontal_scroll": "none — content wraps or truncates within pane"
    },
    "resize_handles": {
      "type": "custom JS drag handles (not CSS resize)",
      "appearance": "thin vertical divider bar (4-6px wide)",
      "cursor": "col-resize",
      "cross_browser": true,
      "supports_n_columns": "2, 3, or 4 panes — one handle between each adjacent pair",
      "implementation": {
        "technique": "mousedown/mousemove/mouseup + pointer capture for reliable drag",
        "touch_support": "touchstart/touchmove/touchend for mobile/tablet",
        "constraints": "enforce min_width_px on both adjacent panes during drag",
        "performance": "use requestAnimationFrame for smooth resize, set flex-basis on panes"
      }
    },
    "theme_tokens": {
      "pane_bg": "neutral-50 (#FAFAFA)",
      "divider_color": "neutral-300 (#D7D9DB)",
      "divider_hover_color": "primary-400 (#73B3F2)",
      "divider_active_color": "primary-500 (#4198F0)",
      "pane_header_bg": "neutral-100 (#F4F5F5)",
      "pane_header_text": "neutral-700 (#5A6168)",
      "row_hover": "primary-50 (#F1F7FE)",
      "row_selected": "primary-100 (#E3F0FC)",
      "row_alternate": "neutral-50 (#FAFAFA)",
      "row_border": "neutral-200 (#EAEBEC)",
      "text_primary": "neutral-900 (#464D53)",
      "text_secondary": "neutral-600 (#6D757E)",
      "male_name_color": "blue",
      "female_name_color": "crimson",
      "button_bg": "primary-100 (#E3F0FC)",
      "button_text": "primary-700 (#126BC4)",
      "button_hover_bg": "primary-200 (#C7E0FA)",
      "font_family": "Arial (from theme uiFont)"
    },
    "responsive": {
      "narrow_screens": "horizontal scroll on container if total min-widths exceed viewport",
      "minimum_viable": "at least 2 panes visible at 768px"
    }
  },
  "notes": [
    "Pane 1 # Players is a server-side aggregated count, not a direct field",
    "Pane 2 uses Registrations as a join table, not displayed as its own pane",
    "Pane 2 email comes from the parent Families record, not Family Members directly",
    "Pane 2 Name column color: blue=Male, crimson=Female",
    "Panes 3 and 4 TBD",
    "Layout uses Chrome split-view pattern with custom JS drag handles between panes",
    "Drag handles support 2-4 panes, work cross-browser including touch devices",
    "Each pane independently vertically scrollable",
    "All colors reference NCE theme tokens from Docs/nce_theme.json"
  ]
}
